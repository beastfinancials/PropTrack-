export const addTransaction = async (tx) => {
const { data, error } = await supabase
.from('transactions')
.insert(tx)
.select()
.single()
if (error) throw error
return data
}
export const deleteTransaction = async (id) => {
const { error } = await supabase.from('transactions').delete().eq('id', id)
if (error) throw error
}
